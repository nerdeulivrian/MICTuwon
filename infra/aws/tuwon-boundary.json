{
  "Version": "2012-10-17",
  "Statement": [
    {
      "Sid": "BoundaryDataPlaneProjectScoped",
      "Effect": "Allow",
      "Action": [
        "dynamodb:GetItem",
        "dynamodb:BatchGetItem",
        "dynamodb:Query",
        "dynamodb:Scan",
        "dynamodb:PutItem",
        "dynamodb:UpdateItem",
        "dynamodb:DeleteItem",
        "dynamodb:DescribeTable"
      ],
      "Resource": [
        "arn:aws:dynamodb:*:*:table/tuwon-*",
        "arn:aws:dynamodb:*:*:table/tuwon-*/index/*"
      ]
    },
    {
      "Sid": "BoundaryS3ProjectScoped",
      "Effect": "Allow",
      "Action": [
        "s3:GetObject",
        "s3:PutObject",
        "s3:DeleteObject",
        "s3:ListBucket"
      ],
      "Resource": [
        "arn:aws:s3:::tuwon-*",
        "arn:aws:s3:::tuwon-*/*"
      ]
    },
    {
      "Sid": "BoundaryObservability",
      "Effect": "Allow",
      "Action": [
        "logs:CreateLogGroup",
        "logs:CreateLogStream",
        "logs:PutLogEvents",
        "xray:PutTraceSegments",
        "xray:PutTelemetryRecords"
      ],
      "Resource": "*"
    }
  ]
}
