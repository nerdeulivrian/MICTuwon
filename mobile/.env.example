# tuwon mobile — environment
#
# Copy to `.env` to point the app at the live payload API. When UNSET the app
# runs entirely on the bundled mock sessions (offline/demo). When set, the
# loader fetches sessions from this API and falls back to the mocks on any
# error (so offline/downloaded sessions still load).
#
# Must be EXPO_PUBLIC_-prefixed: Expo SDK 56 only inlines `process.env.EXPO_PUBLIC_*`
# into the client bundle. Do a full reload after changing it.
#
# Current tuwon-api Function URL (ap-southeast-1 / Singapore):
EXPO_PUBLIC_API_URL=https://rftxk2xx7qqicrcj6x54fzgkxa0zqouv.lambda-url.ap-southeast-1.on.aws
