# Local, machine-specific Claude settings (permissions allow-list etc.)
.claude/settings.local.json

# Dependencies
node_modules/

# Env / secrets
.env
.env.*
!.env.example

# Build output
dist/
build/
.next/
.expo/

# OS / editor
.DS_Store
*.log

